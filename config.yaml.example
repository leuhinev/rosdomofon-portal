server:
  port: 8080

mysql:
  host: localhost
  port: 3306
  user: root
  password: password
  database: portal

memcached:
  address: localhost:11211

rosdomofon:
  email: "machine@example.com"
  password: "your-password"
  sync_interval_minutes: 60
  service_types:
    - Gate
    - VideoSurveillance
    - HouseChat
    - HardwareIntercom
    - SoftwareIntercom
sections:
  enabled:
    - cars
    - keys

log_level: "debug"
jwt_secret: "your-secret-key-change-me"
